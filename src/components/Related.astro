---
interface RelatedItem {
  label: string;
  title: string;
  description: string;
  href: string;
}
interface Props {
  items: RelatedItem[];
}
const { items } = Astro.props;
---
<section class="border-t border-border py-20 bg-bg">
  <div class="max-w-[720px] mx-auto px-6">
    <h3 class="font-display text-[1.6rem] font-normal tracking-tight mb-8">Where to next</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {items.map(item => (
        <a href={item.href} class="p-8 border border-border rounded-xl bg-surface no-underline text-ink flex flex-col gap-2 transition-all hover:border-ink hover:-translate-y-0.5">
          <span class="font-mono text-[0.72rem] uppercase tracking-widest text-ink-faint">{item.label}</span>
          <h4 class="font-display text-[1.5rem] font-normal tracking-tight mt-1">{item.title}</h4>
          <p class="text-[0.9rem] text-ink-soft mt-1.5">{item.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
