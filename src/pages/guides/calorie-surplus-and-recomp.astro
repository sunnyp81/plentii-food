    "description": "Building muscle needs energy — but how much? Lean bulk vs recomposition vs traditional bulk, with the maths and the realistic timelines.",
    "author": { "@type": "Organization", "name": "Plentii", "url": "https://plentii.food" },
    "publisher": { "@type": "Organization", "name": "Plentii", "url": "https://plentii.food" },
