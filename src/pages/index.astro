---
import '../styles/global.css';
import Base from '../layouts/Base.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Plentii",
    "url": "https://plentii.food/",
    "description": "Diet-agnostic UK food guide. Every metric translated, every food scored, every calculator free.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://plentii.food/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Plentii",
    "url": "https://plentii.food/",
    "logo": "https://plentii.food/logo.svg",
    "description": "Diet-agnostic food data and decision tools for UK adults.",
    "sameAs": []
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is plentii a diet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Plentii is a translator. We explain every dieting metric, convert between them, and give you data to make your own decisions. We don't sell a programme, a score, or a plan."
        }
      },
      {
        "@type": "Question",
        "name": "Is it really free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tools, food data, guides, and migration content are free. We fund the site through affiliate commissions on products we genuinely recommend, clearly disclosed."
        }
      },
      {
        "@type": "Question",
        "name": "Are you affiliated with Slimming World or WW?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Plentii is independent. We are not endorsed by, funded by, or commercially connected to any diet programme."
        }
      },
      {
        "@type": "Question",
        "name": "Who writes the content?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A named editorial team with conflicts disclosed. Every page is dated and updated when the evidence changes."
        }
      }
    ]
  }
];

const metrics = [
  { label: 'Calories', value: '105 kcal' },
  { label: 'Syns (SW)', value: '5' },
  { label: 'WW SmartPoints', value: '0' },
  { label: 'Personal Pts', value: '0' },
  { label: 'Protein', value: '1.3 g' },
  { label: 'Fat', value: '0.4 g' },
  { label: 'Carbs', value: '27 g' },
  { label: 'Net carbs', value: '24 g' },
  { label: 'Fibre', value: '3.1 g' },
  { label: 'Sugar', value: '14 g' },
  { label: 'GI', value: '51' },
  { label: 'GL', value: '12' },
  { label: 'NHS portions', value: '1 × 5-a-day' },
  { label: 'Satiety idx', value: '118' },
  { label: 'Diabetic exch.', value: '2' },
];

const pillars = [
  { num: '01', name: 'Calories', audience: 'Universal · NHS · MyFitnessPal' },
  { num: '02', name: 'Syns', audience: 'Slimming World' },
  { num: '03', name: 'WW Points', audience: 'Weight Watchers (legacy)' },
  { num: '04', name: 'SmartPoints', audience: 'WW current' },
  { num: '05', name: 'Zero Points', audience: 'WW free foods' },
  { num: '06', name: 'Macros', audience: 'IIFYM · gym · flexible' },
  { num: '07', name: 'Net Carbs', audience: 'Keto · low-carb' },
  { num: '08', name: 'Alcohol Units', audience: 'UK NHS guidance' },
  { num: '09', name: 'NHS Portions', audience: 'Eatwell Plate' },
  { num: '10', name: 'Exchanges', audience: 'Diabetic management' },
  { num: '11', name: 'GI / GL', audience: 'Blood-sugar response' },
  { num: '12', name: 'Satiety Index', audience: 'Hunger-led eating' },
  { num: '13', name: 'Noom Colour', audience: 'Green / yellow / red' },
  { num: '14', name: 'Zone Blocks', audience: 'Zone Diet' },
  { num: '15', name: 'Volumetrics', audience: 'Energy density' },
];

const tools = [
  { icon: '∑', title: 'TDEE Calculator', desc: 'Maintenance calories, deficit target, surplus target. UK stones-and-pounds inputs.', href: '/tools/tdee-calculator-uk/' },
  { icon: '⇄', title: 'Syns → Calories', desc: 'Convert Slimming World syns to kcal. Learn what the conversion can and can\'t tell you.', href: '/tools/syns-to-calories/' },
  { icon: '⇄', title: 'WW Points → Calories', desc: 'Works for ProPoints, SmartPoints, and Personal Points. All three eras.', href: '/tools/ww-points-to-calories/' },
  { icon: 'P/F/C', title: 'Macros Calculator', desc: 'Protein-first targets for cut, maintain, or lean bulk — with practical UK food examples.', href: '/tools/macros-calculator/' },
  { icon: 'BMI', title: 'BMI Calculator UK', desc: 'Stones-and-pounds inputs. NHS categories. With the limits of BMI explained honestly.', href: '/tools/bmi-calculator-uk/' },
  { icon: 'U', title: 'Alcohol Units', desc: 'Pints, glasses, shots — units and calories together. Track a week against NHS guidance.', href: '/tools/alcohol-units-calculator/' },
];

const bridges = [
  { from: 'Slimming World', to: 'Calorie counting', href: '/migrate/slimming-world-to-calories/' },
  { from: 'WW', to: 'Calorie counting', href: '/migrate/ww-to-calories/' },
  { from: 'Keto', to: 'Flexible eating', href: '/migrate/keto-to-flexible/' },
];

const lifeStages = [
  { title: "Women's nutrition", href: '/life/women/' },
  { title: "Men's nutrition", href: '/life/men/' },
  { title: 'Over 40s', href: '/life/over-40/' },
  { title: 'Over 50s', href: '/life/over-50/' },
];

const startLinks = [
  { label: "I'm on Slimming World", href: '/syns/' },
  { label: "I'm on Weight Watchers", href: '/ww-points/' },
  { label: "I'm counting macros", href: '/macros/' },
  { label: "I'm doing keto", href: '/net-carbs/' },
  { label: "I've never tracked anything", href: '/calories/' },
  { label: "I need a calculator", href: '/#tools' },
];
---

<Base title="Plentii — Eat well in the UK without picking a tribe" description="Diet-agnostic UK food guide. Every metric translated — calories, syns, points, macros, net carbs, units — so you can stop counting someone else's currency and start understanding the food." schema={schema}>

  <!-- Hero -->
  <section class="max-w-[1400px] mx-auto px-6 pt-24 pb-20 md:pt-36 md:pb-28">
    <p class="font-mono text-[0.78rem] uppercase tracking-[0.14em] text-amber mb-5">Diet-agnostic UK food guide</p>
    <h1 class="max-w-[16ch]">Eat well in the UK without picking a tribe.</h1>
    <p class="text-ink-soft text-[1.2rem] max-w-[54ch] mt-6 leading-relaxed">Every diet teaches a different metric. Calories, syns, points, macros, net carbs, units. None of them is the truth on its own. Plentii translates between all of them — so you can stop counting someone else's currency and start understanding the food.</p>
    <div class="flex flex-wrap gap-4 mt-10">
      <a href="/#tools" class="px-6 py-3.5 bg-ink text-bg rounded-full text-[0.95rem] font-medium hover:bg-green-dark transition-colors inline-flex items-center gap-2">Try the tools</a>
      <a href="/about/" class="px-6 py-3.5 border border-border-strong text-ink rounded-full text-[0.95rem] font-medium hover:border-ink transition-colors inline-flex items-center gap-2">What we mean by good eating</a>
    </div>
  </section>

  <!-- Multi-metric chip section -->
  <section class="max-w-[1400px] mx-auto px-6 pb-24">
    <div class="metric-chip-wrap bg-surface border border-border rounded-2xl p-8 md:p-10 max-w-[900px]">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-[2.4rem]">🍌</span>
        <div>
          <h3 class="font-display text-[1.5rem] font-normal tracking-tight">One banana</h3>
          <p class="text-ink-faint text-[0.88rem]">15 metrics. One food. This is what plentii does.</p>
        </div>
      </div>
      <div class="metric-grid" style="display:grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden;">
        {metrics.map(m => (
          <div class="metric-cell" style="background: var(--color-surface); padding: 18px 16px; display: flex; flex-direction: column; gap: 4px;">
            <span class="font-mono text-[0.68rem] uppercase tracking-[0.1em] text-ink-faint">{m.label}</span>
            <span class="value font-display text-[1.4rem] font-medium tracking-tight" style="letter-spacing: -0.02em;">{m.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Metrics pillar grid -->
  <section id="metrics" class="max-w-[1400px] mx-auto px-6 pb-24">
    <div class="flex items-baseline gap-4 mb-8">
      <h2>15 metrics, translated.</h2>
      <p class="text-ink-faint text-[0.95rem]">Every diet teaches one. We cover all of them.</p>
    </div>
    <div class="pillar-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden;">
      {pillars.map(p => (
        <div class="pillar" style="background: var(--color-surface); padding: 22px 24px; display: flex; gap: 16px; align-items: flex-start;">
          <span class="font-mono text-[0.72rem] text-amber font-medium" style="min-width: 24px; padding-top: 4px;">{p.num}</span>
          <div>
            <div class="font-display text-[1.15rem] font-medium tracking-tight">{p.name}</div>
            <div class="text-ink-faint text-[0.85rem] mt-1">{p.audience}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools grid -->
  <section id="tools" class="max-w-[1400px] mx-auto px-6 pb-24">
    <h2 class="mb-8">Free tools.</h2>
    <div class="tools-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px;">
      {tools.map(t => (
        <a href={t.href} class="tool-card bg-surface border border-border rounded-xl p-7 flex flex-col gap-3 no-underline text-ink transition-all hover:border-ink hover:-translate-y-0.5" style="text-decoration: none;">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[0.82rem] text-green bg-green-soft px-2.5 py-1 rounded-md font-medium">{t.icon}</span>
            <h3 class="font-display text-[1.2rem] font-medium tracking-tight">{t.title}</h3>
          </div>
          <p class="text-ink-soft text-[0.92rem] leading-relaxed">{t.desc}</p>
          <span class="text-green text-[0.88rem] font-medium mt-auto">Calculate &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Migration bridges -->
  <section class="max-w-[1400px] mx-auto px-6 pb-24">
    <h2 class="mb-3">Migration bridges.</h2>
    <p class="text-ink-soft text-[1rem] mb-8 max-w-[52ch]">Leaving a programme? We'll translate your knowledge so nothing gets wasted.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {bridges.map(b => (
        <a href={b.href} class="bg-surface border border-border rounded-xl p-7 no-underline text-ink transition-all hover:border-ink hover:-translate-y-0.5 flex flex-col gap-2" style="text-decoration: none;">
          <span class="font-mono text-[0.72rem] uppercase tracking-[0.1em] text-amber">{b.from} &rarr; {b.to}</span>
          <h3 class="font-display text-[1.15rem] font-medium tracking-tight">{b.from} to {b.to.toLowerCase()}</h3>
          <p class="text-ink-soft text-[0.88rem]">What transfers, what doesn't, and how to bridge the gap.</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Life stage entry cards -->
  <section class="max-w-[1400px] mx-auto px-6 pb-24">
    <h2 class="mb-3">By life stage.</h2>
    <p class="text-ink-soft text-[1rem] mb-8 max-w-[52ch]">Nutrition shifts as you age. These guides match the evidence to the decade.</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {lifeStages.map(ls => (
        <a href={ls.href} class="bg-surface border border-border rounded-xl p-7 no-underline text-ink transition-all hover:border-ink hover:-translate-y-0.5 flex flex-col gap-2" style="text-decoration: none;">
          <h3 class="font-display text-[1.15rem] font-medium tracking-tight">{ls.title}</h3>
          <span class="text-green text-[0.85rem] font-medium">Read &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Pick your starting point -->
  <section id="start" class="bg-ink text-bg py-20">
    <div class="max-w-[1400px] mx-auto px-6 text-center">
      <h2 class="text-bg mb-4">Pick your starting point.</h2>
      <p class="text-[rgba(250,247,242,0.6)] text-[1rem] mb-10">No wrong door. Every path leads to the same data.</p>
      <div class="flex flex-wrap justify-center gap-3">
        {startLinks.map(sl => (
          <a href={sl.href} class="px-5 py-3 border border-[rgba(250,247,242,0.2)] rounded-full text-[0.95rem] font-medium text-bg hover:bg-[rgba(250,247,242,0.1)] transition-colors" style="color: var(--color-bg);">{sl.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Principles: What we don't do -->
  <section class="max-w-[1400px] mx-auto px-6 py-24">
    <h2 class="mb-10">What we don't do.</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-surface border border-border rounded-xl p-8">
        <h3 class="font-display text-[1.2rem] font-medium tracking-tight mb-3">No proprietary metric.</h3>
        <p class="text-ink-soft text-[0.95rem] leading-relaxed">We translate existing ones. We don't lock you into a sixteenth.</p>
      </div>
      <div class="bg-surface border border-border rounded-xl p-8">
        <h3 class="font-display text-[1.2rem] font-medium tracking-tight mb-3">No shame language.</h3>
        <p class="text-ink-soft text-[0.95rem] leading-relaxed">No naughty foods, no guilt-free anything, no cheat days.</p>
      </div>
      <div class="bg-surface border border-border rounded-xl p-8">
        <h3 class="font-display text-[1.2rem] font-medium tracking-tight mb-3">No before-and-afters.</h3>
        <p class="text-ink-soft text-[0.95rem] leading-relaxed">Bodies aren't marketing assets. We don't sell transformation.</p>
      </div>
      <div class="bg-surface border border-border rounded-xl p-8">
        <h3 class="font-display text-[1.2rem] font-medium tracking-tight mb-3">No paywall on the data.</h3>
        <p class="text-ink-soft text-[0.95rem] leading-relaxed">Food database, calculators, migration guides — free. Always.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-[720px] mx-auto px-6 pb-24">
    <h2 class="mb-8">Questions.</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Is plentii a diet?</summary>
        <div class="answer">No. Plentii is a translator. We explain every dieting metric, convert between them, and give you data to make your own decisions. We don't sell a programme, a score, or a plan.</div>
      </details>
      <details class="faq-item">
        <summary>Is it really free?</summary>
        <div class="answer">The tools, food data, guides, and migration content are free. We fund the site through affiliate commissions on products we genuinely recommend, clearly disclosed.</div>
      </details>
      <details class="faq-item">
        <summary>Are you affiliated with Slimming World or WW?</summary>
        <div class="answer">No. Plentii is independent. We are not endorsed by, funded by, or commercially connected to any diet programme.</div>
      </details>
      <details class="faq-item">
        <summary>Who writes the content?</summary>
        <div class="answer">A named editorial team with conflicts disclosed. Every page is dated and updated when the evidence changes.</div>
      </details>
    </div>
  </section>

</Base>
